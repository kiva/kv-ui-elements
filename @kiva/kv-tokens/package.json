{
    "name": "@kiva/kv-tokens",
    "version": "4.0.3",
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "main": "index.js",
    "exports": {
        ".": "./index.js",
        "./tokens": "./dist/dtcg/tokens.json",
        "./tokens/*": "./tokens/*",
        "./tailwind": "./configs/tailwind.config.js",
        "./configs/*": "./configs/*",
        "./configs/tailwind.config.js": "./configs/tailwind.config.js",
        "./configs/kivaColors.js": "./configs/kivaColors.js",
        "./configs/kivaTypography.js": "./configs/kivaTypography.js",
        "./js": "./dist/js/tokens.js",
        "./css": "./dist/css/tokens.css",
        "./scss": "./dist/scss/tokens.scss"
    },
    "files": [
        "index.js",
        "configs/",
        "dist/",
        "assets/",
        "tokens/"
    ],
    "scripts": {
        "test": "node --test",
        "lint": "eslint --ext .js ./",
        "build:tokens": "style-dictionary build --config ./build/style-dictionary.config.js",
        "build:dtcg": "node ./build/build-dtcg.js",
        "build": "rimraf dist && npm run build:tokens && npm run build:dtcg && node ./build/build",
        "prepare": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kiva/kv-ui-elements.git"
    },
    "bugs": {
        "url": "https://github.com/kiva/kv-ui-elements/issues"
    },
    "homepage": "https://github.com/kiva/kv-ui-elements/tree/main/%40kiva/kv-tokens#readme",
    "dependencies": {
        "@tailwindcss/typography": "^0.5.1",
        "tailwindcss": "^3.4.3"
    },
    "devDependencies": {
        "style-dictionary": "^4.4.0"
    }
}
